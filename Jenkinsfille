pipeline{
agent any
  tools{
    maven 'Maven'
  }
  stages{
    stage('Checkout'){
      steps{
        git branch:'main',url:'https://github.com/chinmayiii/mavenlistvedio.git'
      }
    }
    stage('Build'){
      steps{
        sh 'build'
      }
    }
    stage('Test'){
      steps{
        sh 'gradle test'
      }
    }
    stage('Run Application'){
      steps{
        sh 'gradle run'
      }
    }
  }
  post{
    success{
      echo 'Build and deployment succesfull'
    }
    failure{
      echo 'Build failed'
    }
  }
}
